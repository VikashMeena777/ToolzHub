    {
      "parameters": {
        "jsCode": "const args = $input.first().json.args || '';\nconst chatId = $input.first().json.chatId;\nconst siteUrl = $input.first().json.siteUrl;\nconst apiSecret = $input.first().json.apiSecret;\nconst parts = args.split('|').map(s => s.trim());\nconst movieName = parts[0] || '';\nconst movieUrl = parts[1] || '';\nconst isValid = movieName.length > 0 && movieUrl.startsWith('http');\nreturn [{ json: { chatId, movieName, movieUrl, isValid, siteUrl, apiSecret } }];"
      },
