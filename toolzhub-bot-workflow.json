    {
      "parameters": {
        "jsCode": "const chatId = $('Extract Command').item.json.chatId;\nconst siteUrl = $('Extract Command').item.json.siteUrl;\nconst movies = $input.first().json.movies || [];\nif (!movies.length) return [{ json: { chatId, text: 'No movies yet! /add to start' } }];\nlet t = `🎬 *Movies* (${movies.length})\\n\\n`;\nmovies.forEach((m,i) => { t += `${i+1}. *${m.name}*\\n   \\`${siteUrl}/go/${m.slug}\\`\\n   👁 ${m.views||0}\\n\\n`; });\nreturn [{ json: { chatId, text: t } }];"
      },
