    {
      "parameters": {
        "jsCode": "const chatId = $('Extract Command').item.json.chatId;\nconst d = $input.first().json;\nlet t = `📊 *Stats*\\n\\n🎬 ${d.totalMovies} movies\\n👁 ${d.totalViews} views\\n\\n`;\nif (d.topMovies && d.topMovies.length) { t += '🏆 *Top:*\\n'; d.topMovies.forEach((m,i) => { t += `${['🥇','🥈','🥉'][i]} ${m.name} - ${m.views}\\n`; }); }\nreturn [{ json: { chatId, text: t } }];"
      },
